rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net: default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVE / GLOBAL HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Valida si el usuario existe en admins/{uid} y active es true
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }

    // Valida si el usuario existe en users/{uid} y tiene rol COMPANY
    function isCompany() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'COMPANY';
    }

    // --- ENTITY VALIDATIONS ---
    
    function isValidUser(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.role is string && (data.role == 'Admin' || data.role == 'Viajero' || data.role == 'Proveedor' || data.role == 'COMPANY' || data.role == 'TRAVELER') &&
             data.status is string && (data.status == 'active' || data.status == 'suspended' || data.status == 'verified' || data.status == 'pending');
    }

    function isValidPost(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.authorId is string && data.authorId.size() <= 128 &&
             data.authorName is string && data.authorName.size() <= 100 &&
             data.imageUrl is string && data.imageUrl.size() <= 1000 &&
             data.location is string && data.location.size() <= 100 &&
             data.likesCount is int &&
             data.title is string && data.title.size() <= 1000 &&
             data.status is string && (data.status == 'Pendiente' || data.status == 'Aprobado');
    }

    // --- ROUTES & MATCH PATTERNS ---

    // Colección de Administradores
    match /admins/{adminId} {
      allow get: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow list, write: if isAdmin();
    }

    // Colección de Usuarios (Viajeros y Prestadores)
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin(); // Bloquea barrido masivo de perfiles
      allow create: if isSignedIn() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isSignedIn() && isValidUser(request.resource.data) && (
        isAdmin() || (
          isOwner(userId) && 
          request.resource.data.role == resource.data.role && 
          request.resource.data.status == resource.data.status && 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'email'])
        )
      );
      allow delete: if isAdmin();
    }

    // Colección de Servicios
    match /services/{serviceId} {
      allow read: if isSignedIn(); // Todos los logueados leen catálogo
      allow create: if isSignedIn() && (
        isAdmin() || (
          isCompany() && 
          request.resource.data.ownerEmail == request.auth.token.email &&
          request.resource.data.isVerified == false &&
          request.resource.data.isRecommended == false &&
          request.resource.data.rating == 0 &&
          request.resource.data.reviewCount == 0
        )
      );
      allow update: if isSignedIn() && (
        isAdmin() || (
          // El dueño del servicio puede editarlo
          resource.data.ownerEmail == request.auth.token.email &&
          request.resource.data.ownerEmail == resource.data.ownerEmail &&
          // Bloqueo de campos de control y reputación
          request.resource.data.isVerified == resource.data.isVerified &&
          request.resource.data.isRecommended == resource.data.isRecommended &&
          request.resource.data.rating == resource.data.rating &&
          request.resource.data.reviewCount == resource.data.reviewCount &&
          (!('status' in resource.data) || request.resource.data.status == resource.data.status)
        )
      );
      allow delete: if isAdmin();
    }

    // Colección de Reservas (Bookings)
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        resource.data.travelerEmail == request.auth.token.email || 
        resource.data.ownerEmail == request.auth.token.email
      );
      allow create: if isSignedIn() && (
        isAdmin() || 
        request.resource.data.travelerEmail == request.auth.token.email
      );
      allow update: if isSignedIn() && (
        isAdmin() || (
          // El viajero solo puede cancelar su reserva
          resource.data.travelerEmail == request.auth.token.email &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
          request.resource.data.status == 'CANCELLED'
        )
      );
      allow delete: if isAdmin();
    }

    // Colección de Promociones
    match /promos/{promoId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        isAdmin() || (
          isCompany() && 
          request.resource.data.ownerEmail == request.auth.token.email &&
          request.resource.data.source == 'business_dashboard' &&
          request.resource.data.isActive == true
        )
      );
      allow update: if isSignedIn() && (
        isAdmin() || 
        // El viajero puede aumentar clics en la app móvil
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clicksCount'])
      );
      allow delete: if isSignedIn() && (
        isAdmin() || 
        resource.data.ownerEmail == request.auth.token.email
      );
    }

    // Colección de Reseñas
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorName is string;
      allow update, delete: if isAdmin();
    }

    // Colección de Publicaciones
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidPost(request.resource.data) && isOwner(request.resource.data.authorId);
      allow update: if isSignedIn() && isValidPost(request.resource.data) && (
        isAdmin() || (
          isOwner(resource.data.authorId) && 
          request.resource.data.status == resource.data.status && 
          request.resource.data.authorId == resource.data.authorId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'title', 'location', 'imageUrl'])
        )
      );
      allow delete: if isAdmin() || (isSignedIn() && isOwner(resource.data.authorId));
    }

    // Colección de Pagos (Historial Admin)
    match /payments/{paymentId} {
      allow read, write: if isAdmin();
    }
  }
}
