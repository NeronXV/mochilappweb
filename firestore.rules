rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Red de seguridad: todo lo no listado explícitamente queda denegado
    match /{document=**} {
      allow read, write: if false;
    }

    // --- HELPERS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    // Admin = documento en admins/{uid} con active == true
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }

    // --- ADMINS ---
    match /admins/{adminId} {
      allow get: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow list, write: if isAdmin();
    }

    // --- USUARIOS (viajeros y empresas) ---
    match /users/{userId} {
      allow get: if isSignedIn();
      // Admin: barrido completo. Cualquier usuario autenticado: solo puede
      // LISTAR empresas (perfiles públicos de negocios), nunca viajeros. Esto
      // habilita los círculos del home y el contacto por WhatsApp sin exponer
      // los perfiles de los viajeros a barridos masivos.
      allow list: if isAdmin() || (isSignedIn() && resource.data.role == 'COMPANY');
      allow create: if isOwner(userId) || isAdmin();
      // El dueño puede editar su perfil (incluido fcmToken) pero no cambiarse
      // el rol ni auto-verificarse como negocio
      allow update: if isAdmin() || (
        isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role', 'businessVerified'])
      );
      allow delete: if isAdmin();
    }

    // --- SERVICIOS ---

    // Coherencia modalidad ↔ pricing (spec modalidad privada/colectiva §6).
    // Servicios legado sin `modalidad` pasan sin validar (compatibilidad).
    function servicePricingValido() {
      let d = request.resource.data;
      return !('modalidad' in d) || (
        d.modalidad == 'COLECTIVA' &&
        d.pricing.precioPorPersona is number && d.pricing.precioPorPersona > 0 &&
        d.pricing.capacidadMaxima is number && d.pricing.capacidadMaxima >= 0
      ) || (
        d.modalidad == 'PRIVADA' &&
        d.pricing.precioBase is number && d.pricing.precioBase > 0 &&
        d.pricing.personasIncluidas is number && d.pricing.personasIncluidas > 0 &&
        d.pricing.precioPersonaExtra is number && d.pricing.precioPersonaExtra >= 0 &&
        d.pricing.capacidadMaxima is number &&
        d.pricing.capacidadMaxima >= d.pricing.personasIncluidas
      );
    }

    match /services/{serviceId} {
      allow read: if isSignedIn();
      // La empresa crea servicios a su nombre, con reputación en cero
      allow create: if isAdmin() || (
        isSignedIn() &&
        request.resource.data.ownerEmail == userEmail() &&
        request.resource.data.rating == 0 &&
        request.resource.data.reviewCount == 0 &&
        request.resource.data.isRecommended == false &&
        servicePricingValido()
      );
      // El dueño edita su servicio sin poder tocar reputación ni dueño
      // (rating/reviewCount los actualiza la Cloud Function onReviewCreated)
      allow update: if isAdmin() || (
        isSignedIn() &&
        resource.data.ownerEmail == userEmail() &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['ownerEmail', 'ownerUid', 'rating', 'reviewCount', 'isRecommended']) &&
        servicePricingValido()
      );
      allow delete: if isAdmin();
    }

    // --- RESERVAS ---
    match /bookings/{bookingId} {
      // Lectura para cualquier usuario autenticado: la app necesita consultar
      // reservas por servicio/fecha para calcular cupos disponibles.
      // TODO endurecer: mover el conteo de cupos a un documento agregado que
      // actualice una Cloud Function, y volver a restringir esta lectura.
      allow read: if isSignedIn();
      allow create: if isAdmin() || (
        isSignedIn() &&
        request.resource.data.travelerEmail == userEmail() &&
        // Solo nacen PENDING: PAID es exclusivo del webhook (Admin SDK)
        request.resource.data.status == 'PENDING' &&
        // Campos autoritativos del servidor (montoTotal = dinero,
        // salidaClaimedAt = desempate de salidas privadas): nunca del cliente.
        // modalidad SÍ la escribe el cliente al crear: es el marcador de que
        // la app entiende la semántica privada (el servidor la sobreescribe
        // con el valor real del servicio al calcular el pago).
        // OJO: el modelo Kotlin serializa montoTotal=0 por defecto en cada
        // create, así que se permite la LLAVE con valor 0; prohibir la llave
        // (hasAny) bloqueaba todo create de la app nueva (sesión 12-jul).
        !('salidaClaimedAt' in request.resource.data) &&
        (!('montoTotal' in request.resource.data) ||
          request.resource.data.montoTotal == 0) &&
        // createdAt honesto: ±10 min de request.time. Evita retro-fechar
        // para ganar el desempate entre PENDINGs y garantiza que el hold
        // de 30 min y expireStalePendingBookings apliquen siempre.
        request.resource.data.createdAt is int &&
        request.resource.data.createdAt - request.time.toMillis() < 10 * 60 * 1000 &&
        request.time.toMillis() - request.resource.data.createdAt < 10 * 60 * 1000
      );
      allow update: if isAdmin() || (isSignedIn() && (
        // Viajero: cancelar SU reserva. PAID solo lo escribe el webhook de
        // Stripe (Admin SDK): un cliente nunca puede marcarse como pagado.
        (resource.data.travelerEmail == userEmail() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
          request.resource.data.status == 'CANCELLED') ||
        // Viajero: check-in "Vive" en SU reserva (solo marca la visita; los
        // MochiPuntos los acredita una Cloud Function con Admin SDK)
        (resource.data.travelerEmail == userEmail() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['travelerCheckedInAt'])) ||
        // Empresa: operar la reserva (check-in / completar / cancelar), sin
        // poder marcarla como pagada (status sin tocar, o a un valor operativo)
        (resource.data.ownerEmail == userEmail() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'checkedInAt', 'checkedInBy', 'completedAt', 'completedBy']) &&
          (request.resource.data.status == resource.data.status ||
            request.resource.data.status in ['CHECKED_IN', 'COMPLETED', 'CANCELLED']))
      ));
      allow delete: if isAdmin();
    }

    // --- PROMOCIONES ---
    match /promos/{promoId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || (
        isSignedIn() && request.resource.data.ownerEmail == userEmail()
      );
      allow update: if isAdmin() || (isSignedIn() && (
        resource.data.ownerEmail == userEmail() ||
        // Cualquier usuario puede aumentar el contador de clics
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clicksCount'])
      ));
      allow delete: if isAdmin() || (
        isSignedIn() && resource.data.ownerEmail == userEmail()
      );
    }

    // --- AVISOS OPERATIVOS (negocio -> viajeros) ---
    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || (
        isSignedIn() && request.resource.data.ownerEmail == userEmail()
      );
      allow update, delete: if isAdmin() || (
        isSignedIn() && resource.data.ownerEmail == userEmail()
      );
    }

    // --- RESEÑAS ---
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.rating is int &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5;
      allow update, delete: if isAdmin();
    }

    // --- PUBLICACIONES (feed social) ---
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Usuarios: solo likes. Moderación (status/destacados) solo admin
      allow update: if isAdmin() || (
        isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['likes', 'likedBy', 'likesCount'])
      );
      allow delete: if isAdmin() || (
        isSignedIn() && resource.data.authorEmail == userEmail()
      );
    }

    // --- COMENTARIOS ---
    match /comments/{commentId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // --- HISTORIAS EFÍMERAS (empresa -> viajeros, 24h) ---
    match /stories/{storyId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || (
        isSignedIn() && request.resource.data.ownerEmail == userEmail()
      );
      allow update, delete: if isAdmin() || (
        isSignedIn() && resource.data.ownerEmail == userEmail()
      );
    }

    // --- PAGOS (historial admin) ---
    match /payments/{paymentId} {
      allow read, write: if isAdmin();
    }
  }
}
